PORT=5173

# OpenAI 兼容 API 配置
# 支持: OpenAI, Kimi, DeepSeek, Groq, 本地模型 等
# 生产环境：这些值只在 Vercel 后端可见，前端永远看不到

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 其他提供商示例:
# OPENAI_BASE_URL=https://api.moonshot.cn/v1  (Kimi)
# OPENAI_BASE_URL=https://api.deepseek.com/v1  (DeepSeek)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1  (Groq)
# OPENAI_BASE_URL=http://localhost:1234/v1  (LM Studio)

# GitHub 配置（GitHub Actions 用，不需要手动设置）
# GITHUB_TOKEN 由 GitHub Actions 自动提供
# GITHUB_USERNAME 在 scripts/fetch-github.js 中设置